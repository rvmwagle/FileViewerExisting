<?xml version="1.0" encoding="utf-8"?>
<widget id="nichebit.uploadfileview.UploadFileView"
        pluginWidget="true"
        needsEntityContext="true"
        offlineCapable="false"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">

    <name>File Viewer</name>
    <description>View and download files with popup viewer. Works with FileDocument entities.</description>

    <!-- Base64 encoded nb.svg icon -->
    <icon>

    </icon>

    <properties>
        <propertyGroup caption="Data Source">
            <property key="fileDocument" type="file" required="true">
                <caption>File Document</caption>
                <description>FileDocument or generalized entity containing the file</description>
            </property>
        </propertyGroup>

        <propertyGroup caption="Viewer Settings">
            <property key="viewButtonText" type="string" defaultValue="View">
                <caption>View Button Text</caption>
                <description>Text displayed on view button</description>
            </property>
            <property key="popupTitle" type="string" defaultValue="File Viewer">
                <caption>Popup Title</caption>
                <description>Title of the popup window</description>
            </property>
            <property key="popupWidth" type="string" defaultValue="80%">
                <caption>Popup Width</caption>
                <description>Width of popup (e.g., 80%, 800px)</description>
            </property>
            <property key="popupHeight" type="string" defaultValue="80%">
                <caption>Popup Height</caption>
                <description>Height of popup (e.g., 80%, 600px)</description>
            </property>
        </propertyGroup>

        <propertyGroup caption="Appearance">
            <property key="showFileName" type="boolean" defaultValue="true">
                <caption>Show File Name</caption>
                <description>Display the file name</description>
            </property>
            <property key="showViewButton" type="boolean" defaultValue="true">
                <caption>Show View Button</caption>
                <description>Show button to view/preview file</description>
            </property>
            <property key="showDownloadButton" type="boolean" defaultValue="true">
                <caption>Show Download Button</caption>
                <description>Show button to download file</description>
            </property>
            <property key="showFileTypeIcon" type="boolean" defaultValue="true">
                <caption>Show File Type Icon</caption>
                <description>Display icon based on file type</description>
            </property>
            <property key="buttonStyle" type="enumeration" defaultValue="primary">
                <caption>View Button Style</caption>
                <description>Style of the view button</description>
                <enumerationValues>
                    <enumerationValue key="primary">Primary</enumerationValue>
                    <enumerationValue key="secondary">Secondary</enumerationValue>
                    <enumerationValue key="success">Success</enumerationValue>
                    <enumerationValue key="info">Info</enumerationValue>
                    <enumerationValue key="warning">Warning</enumerationValue>
                    <enumerationValue key="danger">Danger</enumerationValue>
                </enumerationValues>
            </property>
        </propertyGroup>

        <propertyGroup caption="Messages">
            <property key="noFileMessage" type="string" defaultValue="No file available">
                <caption>No File Message</caption>
                <description>Message when no file is available</description>
            </property>
            <property key="previewNotAvailableMessage" type="string"
                      defaultValue="Preview not available for this file type. Please download the file.">
                <caption>Preview Not Available Message</caption>
                <description>Message when file cannot be previewed</description>
            </property>
        </propertyGroup>
    </properties>
</widget>
